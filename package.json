{
  "name": "do-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install:all": "npm install",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "build:frontend": "cd web && npx vite build",
    "start": "node backend/dist/index.js",
    "dev:backend": "npx ts-node backend/src/index.ts",
    "dev:frontend": "cd web && npx vite",
    "lint": "cd web && npx eslint .",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:backend": "cd backend && npx tsc --noEmit",
    "typecheck:frontend": "cd web && npx tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-calendar": "^6.0.1",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prisma": "5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
